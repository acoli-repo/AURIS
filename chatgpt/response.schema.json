{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Givenness annotation",
  "description": "An array of sentences, each a list of tokens with id, form, coref, givenness.",
  "type": "array",
  "items": {
    "type": "array",
    "items": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer"
        },
        "form": {
          "type": "string"
        },
        "coref": {
          "type": "string"
        },
        "givenness": {
          "type": "string",
          "enum": ["FOCUS", "ACTIVATED", "FAMILIAR", "UNIQUE", "REFERENTIAL", "NEW"]
        }
      },
      "required": ["form"],
      "additionalProperties": false
    }
  }
}
