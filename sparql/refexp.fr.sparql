# other-NP: any def-np that contains "other" => .other suffix
# skipped for French
# DELETE {
#	?w conll:REF_EXP ?old.
#} INSERT {
#	?w conll:REF_EXP ?new
#} WHERE {
#	?other conll:LEMMA "other"; conll:HEAD ?w.
#	?w conll:REF_EXP ?old. FILTER(strstarts(?old,"def-np"))	
#	BIND(concat(?old,".other") as ?new)
#};

# indef-np.a
INSERT {
	?w conll:REF_EXP "indef-np.a"; conll:REF "?NEW"
} WHERE {
	?det conll:FEATS ?f; conll:UPOS "DET"; conll:HEAD ?w.
	FILTER(contains(?f,"Definite=Ind"))
	?w conll:UPOS "NOUN".
	MINUS { ?w conll:REF [] }
};

# indef-np.quant
# French: explicit numerals, only
INSERT {
	?w conll:REF_EXP "indef-np.quant"; conll:REF "?NEW"
} WHERE {
	?quant conll:UPOS "NUM".
	?quant conll:HEAD ?w.
	?w conll:UPOS "NOUN".
	MINUS { ?w conll:REF [] }
};

# indef-np.bare: no determiner
INSERT {
	?w conll:REF_EXP "indef-np.bare"; conll:REF "?NEW"
} WHERE {
	?w conll:UPOS "NOUN".
	MINUS { ?w conll:REF [] }
	MINUS { [ conll:UPOS "DET" ] conll:HEAD ?w }
};

# indef-np: generic indefinite np
INSERT {
	?w conll:REF_EXP "indef-np"; conll:REF "?NEW"
} WHERE {
	?w conll:UPOS "NOUN".
	MINUS { ?w conll:REF [] }
};

# other
INSERT {
	?w conll:REF_EXP "other"; conll:REF "?NEW"
} WHERE {
	?w conll:EDGE ?e.
	FILTER(regex(?e,":.*","") in ("nmod", "nsubj", "obj", "dobj", "iobj", "obl"))
	MINUS { ?w conll:REF [] }
};

##################
# postprocessing #
##################

# remove `?NEW`
# note: this is to facilitate spreadsheet-based annotation, so people can use <CTRL>+<DOWN> to jump to the next primary markable
#       for doing the same for secondary markables, annotators should use the `REF_EXP` column. 

DELETE {
	?w conll:REF "?NEW"
} WHERE {
	?w conll:REF "?NEW"
};


# rename REF_EXP to NP_TYPE (for consistency with Chiarcos and Krasavina 2005)
DELETE {
	?w conll:REF_EXP ?re
} INSERT {
	?w conll:NP_TYPE ?re
} WHERE {
	?w conll:REF_EXP ?re
	};