PREFIX conll: <http://ufal.mff.cuni.cz/conll2009-st/task-description.html#> 
PREFIX nif:   <http://persistence.uni-leipzig.org/nlp2rdf/ontologies/nif-core#> 
PREFIX powla: <http://purl.org/powla/powla.owl#> 
PREFIX rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> 
PREFIX rdfs:  <http://www.w3.org/2000/01/rdf-schema#> 
PREFIX terms: <http://purl.org/acoli/open-ie/> 
PREFIX x:     <http://purl.org/acoli/conll-rdf/xml#> 

###########################
# eliminate non-markables #
###########################

# non-markables (REF=_)
INSERT { ?w conll:REF "_" } 
WHERE { 
	# Reflexive pronouns (English *herself*, etc.) are not PM.
	{ ?w conll:FEATS ?f FILTER(contains(?f,"Reflex=Yes")) } UNION 	# confirmed for French UD (elle-même, eux-mêmes, ...)
	# expletives
	{ ?w conll:EDGE ?e FILTER(strstarts(?e,"expl"))} UNION			# confirmed for French UD (expl:comp, expl:pass, expl:subj)
	# dependent nouns
	{ ?w conll:EDGE "flat"} UNION
	{ ?w conll:EDGE "compound"} UNION
	# relatve pronouns
	{ ?w conll:EDGE "mark"} UNION
	{ ?w conll:UPOS "SCONJ" } UNION
	{ ?w conll:FEATS ?f FILTER(contains(?f,"PronType=Rel"))} UNION	# confirmed for French UD (dont, fou, lequel, ...)
	# non-nominals
	{ ?w conll:EDGE "amod"} UNION
	{ ?w conll:EDGE "advmod"} 
};

#################################
# REF_EXP (NP_TYPE) annotations #
#################################

# REF_EXP
# - indefinite and interrogative pronouns => ?NEW
# - NP with indefinite "semi-demonstrative" (English "such") => ?NEW
# - NAME proper names => ?OLD ("primary markable")
# - DEF_NP definite NP => ?OLD
# - DEM_NP demonstrative NP => ?OLD
# - POSS_NP possessive NP => ?NEW
# - INDEF_NP indefinite NP => ?NEW (secondary markable)
# - PPER personal pronouns => ?OLD
# - PPOSS possessive pronouns => ?OLD
# - PDEM substitutive demonstrative pronouns => ?OLD
# - PADV pronominal adverbs => ?OLD
# - PIND indefinite pronoun => ?NEW (secondary markable)

# Note: to facilitate navigation during spreadsheet-based annotation, we remove `?NEW` in a final processing step.

# - interrogative pronouns => ?NEW
INSERT {
	?w conll:REF "?NEW"; conll:REF_EXP "pron.pint"
} WHERE {
	?w conll:FEATS ?f FILTER(contains(?f,"PronType=Int"))		# confirmed for French UD (où, que, qui, quoi, ...)
	MINUS { ?w conll:REF [] }
};

# - NP with indefinite "semi-demonstrative" (English "such") => ?NEW
# seems to use "tel" in French, but annotates as adjective => not applicable
#INSERT {
#	?w conll:REF "?NEW"; conll:REF_EXP "pron.pds"
#} WHERE {
#	?dep conll:LEMMA "such"; conll:EDGE ?e; conll:HEAD ?w.
#	FILTER(strstarts(?e,"det") || strstarts(?e,"amod"))
#	MINUS { ?w conll:REF [] }
#};

# - PPOSS possessive pronouns => ?OLD
INSERT {
	?w conll:REF_EXP "pron.ppos"; conll:REF "?OLD"
} WHERE {
	?w conll:FEATS ?f.
	FILTER(regex(".*PronType=Prs",?f))
	FILTER(regex(".*Poss=Yes",?f))			# e.g., French son
	MINUS { ?w conll:REF [] }
};

# - PDEM substitutive demonstrative pronouns => ?OLD
INSERT {
	?w conll:REF_EXP "pron.pds"; conll:REF "?OLD"
} WHERE {
	?w conll:UPOS "PRON"; conll:FEATS ?f.
	FILTER(contains(?f,"PronType=Dem"))		# e.g., French ce, ça, cela, celui, celui-ci
	MINUS { ?w conll:REF [] }
};

# - PADV pronominal adverbs => ?OLD, REF_EXP = pron.padv
# English: adverbs containing there, and thence
# French: not distinguished from other adverbs (checked for donc and là), hence not annotated
#INSERT {
#	?w conll:REF_EXP "pron.padv"; conll:REF "?OLD"
#} WHERE {
#	?w conll:UPOS "ADV"; conll:LEMMA ?l.
#	filter(strstarts(?l,"there") || strstarts(?l,"here") || strstarts(?l,"thence") || strstarts(?l,"hence"))
#	MINUS { ?w conll:REF [] }
#};

# - PIND indefinite pronoun => ?NEW (secondary markable)
INSERT {
	?w conll:REF "?NEW"; conll:REF_EXP "pron.pind"
} WHERE {
	?w conll:FEATS ?f FILTER(contains(?f,"PronType=Ind"))  # e.g., French quiconque
	MINUS { ?w conll:REF [] }
};

# - PPER personal pronouns => ?OLD
INSERT {
	?w conll:REF_EXP "pron.pper"; conll:REF "?OLD"
} WHERE {
	?w conll:FEATS ?f FILTER(contains(?f,"PronType=Prs")) # e.g., French il, le, lui, se, vous, nous, je
	MINUS { ?w conll:REF [] }
};

# - other pronouns => ?OLD
INSERT {
	?w conll:REF_EXP "pron"; conll:REF "?OLD"
} WHERE {
	?w conll:UPOS "PRON".
	MINUS { ?w conll:REF [] }
};

INSERT {
	?w conll:REF_EXP "ne"; conll:REF "?OLD"
} WHERE {
	?w conll:UPOS "PROPN".
	MINUS { ?w conll:EDGE "compound" }
	MINUS { ?w conll:EDGE "flat" }
	MINUS { ?w conll:REF [] }
};

INSERT {
	?w conll:REF_EXP "def-np.dem"; conll:REF "?OLD"
} WHERE {
	?def conll:FEATS ?f; conll:EDGE "det"; conll:HEAD ?w.	
	FILTER(contains(?f,"PronType=Dem"))						# French ce 
	?w conll:UPOS "NOUN"
	MINUS { ?w conll:REF [] }
};

INSERT {
	?w conll:REF_EXP "def-np.poss"; conll:REF "?OLD"
} WHERE {
	?def conll:EDGE "det"; conll:FEATS ?f; conll:HEAD ?w.
	FILTER(contains(?f,"Poss=Yes"))							# French son
	?w conll:UPOS "NOUN"
	MINUS { ?w conll:REF [] }
};

INSERT {
	?w conll:REF_EXP "def-np.poss"; conll:REF "?OLD"
} WHERE {
	?of conll:LEMMA "de"; conll:EDGE "case"; conll:HEAD ?dep.	# e.g., French "la famille des de les musiciens"
	?dep conll:EDGE "nmod"; conll:HEAD ?w; conll:REF "?OLD"
	MINUS { ?w conll:REF [] }
};

INSERT {
	?w conll:REF_EXP "def-np.the"; conll:REF "?OLD"
} WHERE {
	?def conll:UPOS "DET"; conll:FEATS ?f; conll:HEAD ?w.
	FILTER(contains(?f,"Definite=Def"))
	?w conll:UPOS "NOUN"
	MINUS { ?w conll:REF [] }
};

# quant-NP: this is for *both N* and *the CARD N*
# skipped for French
# INSERT {
